# Optional WebSocket URL override for multi-device sync.
# By default, the app auto-resolves to same-origin `/ws`.
# VITE_WS_URL=ws://localhost:8080/ws

# Comma-separated allowed browser origins for WebSocket connections.
# Example:
# WS_ALLOWED_ORIGINS=https://rsvp.n0name.eu,https://staging.rsvp.n0name.eu

# Optional abuse-control limits (defaults shown):
# MAX_MESSAGE_BYTES=32768
# MAX_TEXT_LENGTH=200000
# MAX_WORD_INDEX=10000000
# RATE_LIMIT_WINDOW_MS=1000
# RATE_LIMIT_MAX_MESSAGES=60
